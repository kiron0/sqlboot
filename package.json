{
  "name": "sqlboot",
  "version": "1.0.4",
  "description": "Cross-platform npm CLI for Oracle SQL*Plus, Docker Oracle XE, rlwrap, and the sqlboot command.",
  "author": {
    "name": "SQLBoot contributors",
    "url": "https://github.com/InsightLabsIO/sqlboot"
  },
  "contributors": [
    {
      "name": "Shoaib Taimur",
      "url": "https://taimur.dev"
    },
    {
      "name": "Toufiq Hasan Kiron",
      "url": "https://kiron.dev"
    }
  ],
  "license": "MIT",
  "homepage": "https://sqlboot.js.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InsightLabsIO/sqlboot.git"
  },
  "bugs": {
    "url": "https://github.com/InsightLabsIO/sqlboot/issues"
  },
  "bin": {
    "sqlboot": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "sqlboot",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "check": "npm run build && bash -n sqlboot && npm run test",
    "prepack": "npm run build",
    "test": "vitest run",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "oracle",
    "sqlplus",
    "docker",
    "oracle-xe",
    "cli",
    "installer",
    "sqlboot"
  ],
  "engines": {
    "node": ">=16"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "terser": "^5.46.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
