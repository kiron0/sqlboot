#!/usr/bin/env bash
#
# sqlboot
# Cross-platform installer and launcher for Docker Oracle XE, Oracle SQL*Plus,
# and rlwrap on macOS and Ubuntu-based Linux.
#
# First run:
#   chmod +x sqlboot
#   ./sqlboot init
#
# After setup:
#   sqlboot start
#   SQL> conn system/1234@XE

set -Eeuo pipefail

# -----------------------------
# Defaults
# -----------------------------

APP_NAME="sqlboot"
INSTALL_PATH="/usr/local/bin/sqlboot"

ORACLE_IMAGE="${SQLBOOT_ORACLE_IMAGE:-gvenzl/oracle-xe:21-slim}"
ORACLE_CONTAINER="${SQLBOOT_ORACLE_CONTAINER:-oracle-xe}"
ORACLE_PASSWORD="${SQLBOOT_ORACLE_PASSWORD:-1234}"
ORACLE_PORT="${SQLBOOT_ORACLE_PORT:-1521}"
ORACLE_SERVICE="${SQLBOOT_ORACLE_SERVICE:-XEPDB1}"

ORACLE_BASE_DIR="${SQLBOOT_ORACLE_BASE_DIR:-$HOME/oracle}"
INSTANTCLIENT_PARENT="${SQLBOOT_INSTANTCLIENT_PARENT:-$ORACLE_BASE_DIR/instantclient}"
TNS_ADMIN_DIR="$INSTANTCLIENT_PARENT/network/admin"
TNSNAMES_FILE="$TNS_ADMIN_DIR/tnsnames.ora"
SQLPLUS_HISTORY="${SQLBOOT_SQLPLUS_HISTORY:-$HOME/.sqlplus_history}"

READY_TIMEOUT_SECONDS="${SQLBOOT_READY_TIMEOUT_SECONDS:-900}"
DOCKER_READY_TIMEOUT_SECONDS="${SQLBOOT_DOCKER_READY_TIMEOUT_SECONDS:-180}"
DOWNLOAD_CONNECT_TIMEOUT_SECONDS="${SQLBOOT_DOWNLOAD_CONNECT_TIMEOUT_SECONDS:-20}"
DOWNLOAD_MAX_TIME_SECONDS="${SQLBOOT_DOWNLOAD_MAX_TIME_SECONDS:-900}"
DOWNLOAD_SPEED_LIMIT_BYTES="${SQLBOOT_DOWNLOAD_SPEED_LIMIT_BYTES:-1024}"
DOWNLOAD_SPEED_TIME_SECONDS="${SQLBOOT_DOWNLOAD_SPEED_TIME_SECONDS:-30}"

LINUX_IC_VERSION="21.19.0.0.0dbru"
# Oracle publishes 21.x ZIPs for Linux x86_64. For macOS Intel, Oracle's
# public Instant Client ZIP packages are 19.x and are compatible with Oracle
# Database 21c. Override SQLBOOT_IC_BASIC_URL and SQLBOOT_IC_SQLPLUS_URL if
# you have a different macOS package source.
MACOS_IC_VERSION="19.8.0.0.0dbru"
LINUX_IC_DIR_VERSION="2119000"
MACOS_IC_DIR_VERSION="198000"

LINUX_BASIC_URL_DEFAULT="https://download.oracle.com/otn_software/linux/instantclient/${LINUX_IC_DIR_VERSION}/instantclient-basic-linux.x64-${LINUX_IC_VERSION}.zip"
LINUX_SQLPLUS_URL_DEFAULT="https://download.oracle.com/otn_software/linux/instantclient/${LINUX_IC_DIR_VERSION}/instantclient-sqlplus-linux.x64-${LINUX_IC_VERSION}.zip"
MACOS_BASIC_URL_DEFAULT="https://download.oracle.com/otn_software/mac/instantclient/${MACOS_IC_DIR_VERSION}/instantclient-basic-macos.x64-${MACOS_IC_VERSION}.zip"
MACOS_SQLPLUS_URL_DEFAULT="https://download.oracle.com/otn_software/mac/instantclient/${MACOS_IC_DIR_VERSION}/instantclient-sqlplus-macos.x64-${MACOS_IC_VERSION}.zip"

OS_TYPE=""
OS_ARCH=""
IS_WSL="0"
PROFILE_FILE=""
LIB_PATH_VAR=""
IC_BASIC_URL=""
IC_SQLPLUS_URL=""
DOCKER_PLATFORM_ARGS=()
DETECT_OS_QUIET="0"

# -----------------------------
# Logging
# -----------------------------

log_info() {
  printf '[INFO] %s\n' "$*"
}

log_ok() {
  printf '[OK] %s\n' "$*"
}

log_error() {
  printf '[ERROR] %s\n' "$*" >&2
}

die() {
  log_error "$*"
  exit 1
}

on_error() {
  local exit_code=$?
  local line_no=${1:-unknown}
  log_error "Command failed near line ${line_no}. Exit code: ${exit_code}"
  exit "$exit_code"
}

trap 'on_error "$LINENO"' ERR

# -----------------------------
# Common helpers
# -----------------------------

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

need_sudo() {
  [[ "${EUID:-$(id -u)}" -ne 0 ]]
}

run_sudo() {
  if need_sudo; then
    sudo -p "[sudo] Enter Ubuntu/Linux password for %u: " "$@"
  else
    "$@"
  fi
}

ensure_dir() {
  mkdir -p "$1"
}

append_once() {
  local file=$1
  local marker=$2
  local block=$3

  touch "$file"
  if grep -Fq "$marker" "$file"; then
    log_ok "Environment block already present in $file"
    return 0
  fi

  {
    printf '\n%s\n' "$marker"
    printf '%s\n' "$block"
  } >>"$file"
  log_ok "Updated $file"
}

remove_between_markers() {
  local file=$1
  local start_marker=$2
  local end_marker=$3

  [[ -f "$file" ]] || return 0
  if ! grep -Fq "$start_marker" "$file"; then
    log_ok "No sqlboot environment block found in $file"
    return 0
  fi

  local tmp_file
  tmp_file="$(mktemp)"
  awk -v start="$start_marker" -v end="$end_marker" '
    $0 == start { skipping = 1; next }
    $0 == end { skipping = 0; next }
    !skipping { print }
  ' "$file" >"$tmp_file"
  mv "$tmp_file" "$file"
  log_ok "Removed sqlboot environment block from $file"
}

remove_file_if_exists() {
  local file=$1
  if [[ -e "$file" || -L "$file" ]]; then
    rm -f "$file"
    log_ok "Removed $file"
  else
    log_ok "$file does not exist"
  fi
}

remove_dir_if_exists() {
  local dir=$1
  if [[ -z "$dir" || "$dir" == "/" || "$dir" == "$HOME" ]]; then
    die "Refusing to remove unsafe directory path: ${dir:-empty}"
  fi

  if [[ -d "$dir" ]]; then
    rm -rf "$dir"
    log_ok "Removed $dir"
  else
    log_ok "$dir does not exist"
  fi
}

latest_instantclient_dir() {
  local dir
  dir="$(find "$INSTANTCLIENT_PARENT" -maxdepth 1 -type d -name 'instantclient_*' 2>/dev/null | sort | tail -n 1 || true)"
  printf '%s\n' "$dir"
}

sqlplus_path() {
  local dir
  dir="$(latest_instantclient_dir)"
  if [[ -n "$dir" && -x "$dir/sqlplus" ]]; then
    printf '%s\n' "$dir/sqlplus"
  fi
}

require_command() {
  command_exists "$1" || die "Required command not found: $1"
}

# -----------------------------
# OS detection
# -----------------------------

detect_os() {
  OS_ARCH="$(uname -m)"
  IS_WSL="0"

  case "$(uname -s)" in
    Darwin)
      OS_TYPE="macos"
      PROFILE_FILE="$HOME/.zshrc"
      LIB_PATH_VAR="DYLD_LIBRARY_PATH"
      IC_BASIC_URL="${SQLBOOT_IC_BASIC_URL:-$MACOS_BASIC_URL_DEFAULT}"
      IC_SQLPLUS_URL="${SQLBOOT_IC_SQLPLUS_URL:-$MACOS_SQLPLUS_URL_DEFAULT}"

      if [[ "$OS_ARCH" == "arm64" ]]; then
        DOCKER_PLATFORM_ARGS=(--platform linux/amd64)
        if [[ "$DETECT_OS_QUIET" != "1" ]]; then
          log_info "Apple Silicon detected. Docker will use linux/amd64 for Oracle XE."
        fi
      elif [[ "$OS_ARCH" != "x86_64" ]]; then
        die "Unsupported macOS architecture: $OS_ARCH"
      fi
      ;;

    Linux)
      OS_TYPE="linux"
      PROFILE_FILE="$HOME/.bashrc"
      LIB_PATH_VAR="LD_LIBRARY_PATH"
      IC_BASIC_URL="${SQLBOOT_IC_BASIC_URL:-$LINUX_BASIC_URL_DEFAULT}"
      IC_SQLPLUS_URL="${SQLBOOT_IC_SQLPLUS_URL:-$LINUX_SQLPLUS_URL_DEFAULT}"

      if [[ -n "${WSL_DISTRO_NAME:-}" ]] || grep -qiE 'microsoft|wsl' /proc/sys/kernel/osrelease 2>/dev/null; then
        IS_WSL="1"
      fi

      if [[ -r /etc/os-release ]]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        local distro="${ID:-}"
        local like="${ID_LIKE:-}"
        if [[ "$distro" != "ubuntu" && "$distro" != "zorin" && "$like" != *"ubuntu"* && "$like" != *"debian"* ]]; then
          die "Unsupported Linux distribution: ${PRETTY_NAME:-unknown}. This installer supports Ubuntu-based Linux, including Zorin OS."
        fi
      else
        die "Cannot detect Linux distribution because /etc/os-release is missing."
      fi

      if [[ "$OS_ARCH" != "x86_64" && "$OS_ARCH" != "amd64" ]]; then
        die "Unsupported Linux architecture: $OS_ARCH. Oracle Instant Client 21.x defaults here require x86_64."
      fi
      ;;

    *)
      die "Unsupported operating system: $(uname -s)"
      ;;
  esac

  if [[ "$DETECT_OS_QUIET" != "1" ]]; then
    if [[ "$IS_WSL" == "1" ]]; then
      log_ok "Detected $OS_TYPE ($OS_ARCH, WSL)"
    else
      log_ok "Detected $OS_TYPE ($OS_ARCH)"
    fi
  fi
}

# -----------------------------
# Package manager setup
# -----------------------------

install_homebrew_if_missing() {
  if command_exists brew; then
    log_ok "Homebrew is already installed"
    return 0
  fi

  log_info "Installing Homebrew"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi

  command_exists brew || die "Homebrew installation completed, but brew is not available in PATH."
  log_ok "Homebrew installed"
}

install_packages_macos() {
  install_homebrew_if_missing

  log_info "Installing required macOS packages"
  brew list curl >/dev/null 2>&1 || brew install curl
  brew list unzip >/dev/null 2>&1 || brew install unzip
  brew list rlwrap >/dev/null 2>&1 || brew install rlwrap
  log_ok "Required macOS packages are available"
}

install_packages_linux() {
  require_command apt-get

  log_info "Installing required Linux packages"
  run_sudo apt-get update
  run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y curl unzip rlwrap ca-certificates
  install_libaio_package
  ensure_libaio_runtime
  run_sudo apt-get clean
  log_ok "Required Linux packages are available"
}

install_libaio_package() {
  if dpkg -s libaio1 >/dev/null 2>&1 || dpkg -s libaio1t64 >/dev/null 2>&1 || dpkg -s libaio-dev >/dev/null 2>&1; then
    return 0
  fi

  local package_name
  for package_name in libaio1t64 libaio1 libaio-dev; do
    if apt-cache show "$package_name" >/dev/null 2>&1 && run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y "$package_name"; then
      return 0
    fi
  done

  if command_exists add-apt-repository; then
    run_sudo add-apt-repository -y universe || true
  else
    run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y software-properties-common && \
      run_sudo add-apt-repository -y universe || true
  fi

  if [[ -d /etc/apt/sources.list.d ]]; then
    local source_file
    for source_file in /etc/apt/sources.list.d/*.sources; do
      [[ -f "$source_file" ]] || continue
      if grep -q '^Components:' "$source_file" && ! grep -q '^Components:.*universe' "$source_file"; then
        run_sudo sed -i 's/^Components: \(.*\)$/Components: \1 universe/' "$source_file"
      fi
    done
  fi

  run_sudo apt-get update
  for package_name in libaio1t64 libaio1 libaio-dev; do
    if apt-cache show "$package_name" >/dev/null 2>&1 && run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y "$package_name"; then
      return 0
    fi
  done

  local arch
  arch="$(dpkg --print-architecture 2>/dev/null || true)"
  if [[ "$arch" == "amd64" ]]; then
    local tmp_deb
    tmp_deb="$(mktemp)"
    local deb_url="https://archive.ubuntu.com/ubuntu/pool/main/liba/libaio/libaio1t64_0.3.113-8build1_amd64.deb"
    if command_exists curl && curl -fL --retry 3 -o "$tmp_deb" "$deb_url" && run_sudo dpkg -i "$tmp_deb"; then
      rm -f "$tmp_deb"
      return 0
    fi
    rm -f "$tmp_deb"
  fi

  return 1
}

libaio_runtime_available() {
  local spath=${1:-}

  if [[ -n "$spath" && -x "$spath" ]]; then
    if LD_LIBRARY_PATH="$(dirname "$spath"):${LD_LIBRARY_PATH:-}" ldd "$spath" 2>/dev/null | grep -Fq 'libaio.so.1 => not found'; then
      return 1
    fi
    return 0
  fi

  ldconfig -p 2>/dev/null | grep -Fq 'libaio.so.1'
}

ensure_libaio_runtime() {
  [[ "$OS_TYPE" == "linux" ]] || return 0

  local spath
  spath="$(sqlplus_path || true)"

  if libaio_runtime_available "$spath"; then
    return 0
  fi

  require_command apt-get
  log_info "Installing SQL*Plus runtime dependency libaio"
  run_sudo apt-get update
  install_libaio_package || true
  run_sudo apt-get clean

  if libaio_runtime_available "$spath"; then
    return 0
  fi

  local libaio_candidate
  libaio_candidate="$(find /usr/lib /lib -type f \( -name 'libaio.so.1*' -o -name 'libaio.so.*' \) -print 2>/dev/null | sort | head -n 1 || true)"
  if [[ -z "$libaio_candidate" ]]; then
    local arch
    arch="$(dpkg --print-architecture 2>/dev/null || true)"
    if [[ "$arch" == "amd64" ]]; then
      local tmp_dir
      tmp_dir="$(mktemp -d)"
      local deb_path="$tmp_dir/libaio.deb"
      local deb_url
      for deb_url in \
        "https://archive.ubuntu.com/ubuntu/pool/main/liba/libaio/libaio1t64_0.3.113-8build1_amd64.deb" \
        "https://archive.ubuntu.com/ubuntu/pool/main/liba/libaio/libaio1_0.3.113-8_amd64.deb" \
        "https://archive.ubuntu.com/ubuntu/pool/main/liba/libaio/libaio1_0.3.112-13build1_amd64.deb" \
        "https://deb.debian.org/debian/pool/main/liba/libaio/libaio1_0.3.113-4_amd64.deb"
      do
        rm -f "$deb_path"
        if command_exists curl && curl -fL --retry 3 -o "$deb_path" "$deb_url"; then
          rm -rf "$tmp_dir/extract"
          mkdir -p "$tmp_dir/extract"
          dpkg-deb -x "$deb_path" "$tmp_dir/extract" || true
          libaio_candidate="$(find "$tmp_dir/extract" -type f \( -name 'libaio.so.1*' -o -name 'libaio.so.*' \) -print 2>/dev/null | sort | head -n 1 || true)"
          [[ -n "$libaio_candidate" ]] && break
        fi
      done
      if [[ -n "$libaio_candidate" ]]; then
        run_sudo cp "$libaio_candidate" /usr/local/lib/libaio.so.1
        libaio_candidate="/usr/local/lib/libaio.so.1"
      fi
      rm -rf "$tmp_dir"
    fi
  fi
  if [[ -n "$libaio_candidate" ]]; then
    log_info "Linking SQL*Plus runtime dependency libaio.so.1"
    run_sudo ln -sf "$libaio_candidate" /usr/local/lib/libaio.so.1
    if [[ -n "$spath" ]]; then
      run_sudo ln -sf "$libaio_candidate" "$(dirname "$spath")/libaio.so.1"
    fi
    run_sudo ldconfig
  fi

  libaio_runtime_available "$spath" || die "SQL*Plus runtime dependency libaio.so.1 is missing. Install libaio1 or libaio1t64, then rerun sqlboot start."
}

install_required_packages() {
  if [[ "$OS_TYPE" == "macos" ]]; then
    install_packages_macos
  else
    install_packages_linux
  fi

  require_command curl
  require_command unzip
  require_command rlwrap
}

# -----------------------------
# Docker installation and setup
# -----------------------------

docker_is_ready() {
  command_exists docker && docker info >/dev/null 2>&1
}

docker_is_accessible() {
  if docker_is_ready; then
    return 0
  fi

  [[ "$OS_TYPE" == "linux" ]] && need_sudo && run_sudo docker info >/dev/null 2>&1
}

launch_docker_macos() {
  if docker_is_ready; then
    log_ok "Docker is running"
    return 0
  fi

  log_info "Launching Docker Desktop"
  open -a Docker || true

  local elapsed=0
  while (( elapsed < DOCKER_READY_TIMEOUT_SECONDS )); do
    if docker_is_ready; then
      log_ok "Docker is ready"
      return 0
    fi
    sleep 3
    elapsed=$((elapsed + 3))
  done

  die "Docker Desktop did not become ready within ${DOCKER_READY_TIMEOUT_SECONDS}s. Open Docker Desktop once, finish any first-run setup, then run this installer again."
}

install_docker_macos() {
  install_homebrew_if_missing

  if command_exists docker; then
    log_ok "Docker CLI is already installed"
  else
    log_info "Installing Docker Desktop"
    brew install --cask docker
    log_ok "Docker Desktop installed"
  fi

  if [[ "$OS_ARCH" == "arm64" && ! -e /Library/Apple/usr/libexec/oah/libRosettaRuntime ]]; then
    log_info "Installing Rosetta 2 for x86_64 Oracle Instant Client compatibility"
    softwareupdate --install-rosetta --agree-to-license || true
  fi

  launch_docker_macos
}

install_docker_linux() {
  if [[ "$IS_WSL" == "1" ]]; then
    setup_wsl_windows_docker_proxy || true

    if ! command_exists docker; then
      die "Docker CLI was not found in WSL. Start Docker Desktop on Windows, then rerun sqlboot init."
    fi

    if ! docker_is_ready; then
      setup_wsl_windows_docker_proxy || true
    fi

    if ! docker_is_ready; then
      die "Docker is not reachable from WSL. Start Docker Desktop on Windows, then rerun sqlboot init."
    fi

    log_ok "Docker Desktop is reachable from WSL"
    return 0
  fi

  if command_exists docker; then
    log_ok "Docker is already installed"
  else
    log_info "Installing docker.io"
    run_sudo apt-get update
    run_sudo env DEBIAN_FRONTEND=noninteractive apt-get install -y docker.io
    log_ok "docker.io installed"
  fi

  log_info "Enabling Docker service"
  run_sudo systemctl enable docker
  run_sudo systemctl start docker

  if ! docker_is_ready; then
    if need_sudo && run_sudo docker info >/dev/null 2>&1; then
      log_info "Adding current user to docker group"
      run_sudo usermod -aG docker "$USER"
      log_ok "User added to docker group. A new login may be required; this run will use sudo for Docker where needed."
    else
      die "Docker service is not ready."
    fi
  else
    log_ok "Docker is ready"
  fi
}

setup_wsl_windows_docker_proxy() {
  [[ "$IS_WSL" == "1" ]] || return 1

  local docker_cli=""
  local candidate
  for candidate in \
    "/mnt/c/Program Files/Docker/Docker/resources/bin/docker.exe" \
    "/mnt/c/Program Files/Docker/Docker/resources/bin/com.docker.cli.exe"
  do
    if [[ -f "$candidate" ]]; then
      docker_cli="$candidate"
      break
    fi
  done

  [[ -n "$docker_cli" ]] || return 1

  local escaped_docker_cli
  escaped_docker_cli="$(printf '%s' "$docker_cli" | sed "s/'/'\\\\''/g")"
  local docker_cli_dir
  docker_cli_dir="$(dirname "$docker_cli")"
  local escaped_docker_cli_dir
  escaped_docker_cli_dir="$(printf '%s' "$docker_cli_dir" | sed "s/'/'\\\\''/g")"

  local tmp_file
  tmp_file="$(mktemp)"
  {
    printf '%s\n' '#!/usr/bin/env sh'
    printf "DOCKER_CLI_DIR='%s'\n" "$escaped_docker_cli_dir"
    printf '%s\n' 'case ":$PATH:" in'
    printf '%s\n' '  *":$DOCKER_CLI_DIR:"*) ;;'
    printf '%s\n' '  *) PATH="$DOCKER_CLI_DIR:$PATH"; export PATH ;;'
    printf '%s\n' 'esac'
    printf "exec '%s' \"\$@\"\n" "$escaped_docker_cli"
  } >"$tmp_file"
  chmod +x "$tmp_file"

  run_sudo mkdir -p /usr/local/bin
  run_sudo install -m 0755 "$tmp_file" /usr/local/bin/docker
  rm -f "$tmp_file"

  hash -r 2>/dev/null || true
  log_ok "Configured WSL Docker proxy to Docker Desktop"
}

docker_error_is_missing_desktop_credential_helper() {
  grep -Eqi 'docker-credential-desktop.*(not found|executable file not found|no such file|cannot find)'
}

make_temp_docker_config_dir() {
  local temp_parent=""

  if [[ "$IS_WSL" == "1" ]] && command_exists cmd.exe && command_exists wslpath; then
    local windows_temp
    windows_temp="$(cmd.exe /C echo %TEMP% 2>/dev/null | tr -d '\r' | tail -n 1 || true)"
    if [[ -n "$windows_temp" ]]; then
      temp_parent="$(wslpath -u "$windows_temp" 2>/dev/null || true)"
    fi
  fi

  if [[ -n "$temp_parent" ]]; then
    mkdir -p "$temp_parent" 2>/dev/null || true
    if [[ -d "$temp_parent" && -w "$temp_parent" ]]; then
      mktemp -d "$temp_parent/sqlboot-docker-config.XXXXXX" && return 0
    fi
  fi

  mktemp -d
}

make_docker_config_arg_path() {
  local config_dir=$1

  if [[ "$IS_WSL" == "1" ]] && command_exists wslpath; then
    wslpath -w "$config_dir" 2>/dev/null && return 0
  fi

  printf '%s\n' "$config_dir"
}

docker_pull_image() {
  local image=$1
  local output

  if output="$(docker_cmd pull "${DOCKER_PLATFORM_ARGS[@]}" "$image" 2>&1)"; then
    printf '%s\n' "$output"
    return 0
  fi

  if printf '%s\n' "$output" | docker_error_is_missing_desktop_credential_helper; then
    log_info "Docker Desktop credential helper is unavailable; retrying with a temporary Docker config"

    local tmp_docker_config
    tmp_docker_config="$(make_temp_docker_config_dir)"
    printf '%s\n' '{"auths":{}}' >"$tmp_docker_config/config.json"
    local docker_config_arg_path
    docker_config_arg_path="$(make_docker_config_arg_path "$tmp_docker_config")"

    if docker_cmd --config "$docker_config_arg_path" pull "${DOCKER_PLATFORM_ARGS[@]}" "$image"; then
      rm -rf "$tmp_docker_config"
      return 0
    fi

    rm -rf "$tmp_docker_config"
  fi

  printf '%s\n' "$output" >&2
  return 1
}

docker_cmd() {
  if docker_is_ready; then
    docker "$@"
  elif [[ "$OS_TYPE" == "linux" ]] && need_sudo; then
    run_sudo docker "$@"
  else
    docker "$@"
  fi
}

ensure_docker_running() {
  if docker_is_ready; then
    return 0
  fi

  if [[ "$OS_TYPE" == "macos" ]]; then
    launch_docker_macos
  elif [[ "$IS_WSL" == "1" ]]; then
    die "Docker is not reachable from WSL. Start Docker Desktop and enable WSL integration for this distro."
  else
    run_sudo systemctl start docker
    if ! docker_is_ready && ! run_sudo docker info >/dev/null 2>&1; then
      die "Docker is not running and could not be started."
    fi
  fi
}

install_and_setup_docker() {
  if [[ "$OS_TYPE" == "macos" ]]; then
    install_docker_macos
  else
    install_docker_linux
  fi

  ensure_docker_running

  log_info "Pulling Oracle XE image"
  docker_pull_image "$ORACLE_IMAGE"
  log_ok "Oracle XE image is available"

  create_oracle_container
}

container_exists() {
  docker_cmd ps -a --format '{{.Names}}' | grep -Fxq "$ORACLE_CONTAINER"
}

container_is_running() {
  docker_cmd ps --format '{{.Names}}' | grep -Fxq "$ORACLE_CONTAINER"
}

require_docker_cli() {
  command_exists docker || die "Docker CLI not found."
}

require_docker_ready() {
  require_docker_cli
  if ! docker_is_accessible; then
    if [[ "$OS_TYPE" == "macos" ]]; then
      die "Docker not running. Start Docker Desktop."
    elif [[ "$IS_WSL" == "1" ]]; then
      die "Docker not reachable in WSL. Start Docker Desktop, enable WSL integration."
    else
      die "Docker not running. Start Docker service."
    fi
  fi
}

create_oracle_container() {
  if container_exists; then
    log_ok "Container $ORACLE_CONTAINER already exists"
    return 0
  fi

  log_info "Creating Oracle XE container"
  docker_cmd run -d \
    "${DOCKER_PLATFORM_ARGS[@]}" \
    --name "$ORACLE_CONTAINER" \
    -p "${ORACLE_PORT}:1521" \
    -e ORACLE_PASSWORD="$ORACLE_PASSWORD" \
    --restart unless-stopped \
    "$ORACLE_IMAGE" >/dev/null

  log_ok "Container $ORACLE_CONTAINER created"
}

start_oracle_container() {
  ensure_docker_running

  if ! container_exists; then
    create_oracle_container
  fi

  if container_is_running; then
    log_ok "Container $ORACLE_CONTAINER is already running"
  else
    log_info "Starting container $ORACLE_CONTAINER"
    docker_cmd start "$ORACLE_CONTAINER" >/dev/null
    log_ok "Container $ORACLE_CONTAINER started"
  fi
}

wait_for_oracle_ready() {
  log_info "Waiting for Oracle XE to be ready"

  local elapsed=0
  while (( elapsed < READY_TIMEOUT_SECONDS )); do
    if docker_cmd logs --tail 300 "$ORACLE_CONTAINER" 2>&1 | grep -Fq "DATABASE IS READY TO USE"; then
      log_ok "Oracle XE is ready"
      return 0
    fi

    if sqlplus_connection_ready; then
      log_ok "Oracle XE is ready"
      return 0
    fi

    if ! container_is_running; then
      docker_cmd logs --tail 80 "$ORACLE_CONTAINER" >&2 || true
      die "Container $ORACLE_CONTAINER stopped before Oracle XE became ready."
    fi

    sleep 5
    elapsed=$((elapsed + 5))
  done

  docker_cmd logs --tail 120 "$ORACLE_CONTAINER" >&2 || true
  die "Oracle XE did not become ready within ${READY_TIMEOUT_SECONDS}s."
}

sqlplus_connection_ready() {
  local spath
  spath="$(sqlplus_path)"

  if [[ -z "$spath" ]]; then
    return 1
  fi

  export TNS_ADMIN="$TNS_ADMIN_DIR"
  export PATH="$(dirname "$spath"):$PATH"
  export "$LIB_PATH_VAR=$(dirname "$spath"):${!LIB_PATH_VAR:-}"

  printf 'conn system/%s@XE\nexit\n' "$ORACLE_PASSWORD" | "$spath" -L -S /nolog >/dev/null 2>&1
}

# -----------------------------
# Oracle Instant Client setup
# -----------------------------

download_file() {
  local url=$1
  local dest=$2

  if [[ -f "$dest" && -s "$dest" ]]; then
    log_ok "Downloaded file already exists: $(basename "$dest")"
    return 0
  fi

  log_info "Downloading $(basename "$dest")"
  local curl_args=(
    -fL
    --retry 5
    --retry-delay 3
    --connect-timeout "$DOWNLOAD_CONNECT_TIMEOUT_SECONDS"
    --max-time "$DOWNLOAD_MAX_TIME_SECONDS"
    --speed-limit "$DOWNLOAD_SPEED_LIMIT_BYTES"
    --speed-time "$DOWNLOAD_SPEED_TIME_SECONDS"
    -o "$dest"
    "$url"
  )

  if curl --help all 2>/dev/null | grep -Fq -- '--retry-all-errors'; then
    curl_args=(--retry-all-errors "${curl_args[@]}")
  fi

  if ! curl "${curl_args[@]}"; then
    rm -f "$dest"
    die "Download stalled or failed: $(basename "$dest"). Check your connection, then rerun sqlboot init; SQLBoot will retry automatically."
  fi
}

install_instant_client() {
  if [[ -n "$(sqlplus_path)" ]]; then
    log_ok "SQL*Plus is already installed"
    return 0
  fi

  ensure_dir "$INSTANTCLIENT_PARENT"

  local tmp_dir
  tmp_dir="$(mktemp -d)"
  local basic_zip="$tmp_dir/instantclient-basic.zip"
  local sqlplus_zip="$tmp_dir/instantclient-sqlplus.zip"

  download_file "$IC_BASIC_URL" "$basic_zip"
  download_file "$IC_SQLPLUS_URL" "$sqlplus_zip"

  log_info "Extracting Oracle Instant Client"
  unzip -oq "$basic_zip" -d "$INSTANTCLIENT_PARENT"
  unzip -oq "$sqlplus_zip" -d "$INSTANTCLIENT_PARENT"

  local ic_dir
  ic_dir="$(latest_instantclient_dir)"
  [[ -n "$ic_dir" ]] || die "Instant Client extraction did not create an instantclient_* directory."
  [[ -x "$ic_dir/sqlplus" ]] || die "SQL*Plus binary not found after extraction: $ic_dir/sqlplus"

  if [[ "$OS_TYPE" == "linux" ]]; then
    chmod +x "$ic_dir/sqlplus" || true
  fi

  rm -rf "$tmp_dir"
  log_ok "SQL*Plus installed at $ic_dir/sqlplus"
}

# -----------------------------
# Environment and TNS setup
# -----------------------------

setup_tnsnames() {
  ensure_dir "$TNS_ADMIN_DIR"

  cat >"$TNSNAMES_FILE" <<EOF
XE =
  (DESCRIPTION =
    (ADDRESS = (PROTOCOL = TCP)(HOST = localhost)(PORT = ${ORACLE_PORT}))
    (CONNECT_DATA =
      (SERVICE_NAME = ${ORACLE_SERVICE})
    )
  )
EOF

  log_ok "Configured $TNSNAMES_FILE"
}

setup_environment() {
  local ic_dir
  ic_dir="$(latest_instantclient_dir)"
  [[ -n "$ic_dir" ]] || die "Instant Client directory not found."

  local marker="# >>> sqlboot environment >>>"
  local block
  block="$(cat <<EOF
export SQLBOOT_ORACLE_HOME="$ORACLE_BASE_DIR"
export TNS_ADMIN="$TNS_ADMIN_DIR"
export PATH="$ic_dir:\$PATH"
export ${LIB_PATH_VAR}="$ic_dir:\${${LIB_PATH_VAR}:-}"
# <<< sqlboot environment <<<
EOF
)"

  append_once "$PROFILE_FILE" "$marker" "$block"

  export SQLBOOT_ORACLE_HOME="$ORACLE_BASE_DIR"
  export TNS_ADMIN="$TNS_ADMIN_DIR"
  export PATH="$ic_dir:$PATH"
  export "$LIB_PATH_VAR=$ic_dir:${!LIB_PATH_VAR:-}"

  log_ok "Environment is active for this session"
}

setup_rlwrap() {
  touch "$SQLPLUS_HISTORY"
  chmod 600 "$SQLPLUS_HISTORY" || true
  log_ok "SQL*Plus history file is ready at $SQLPLUS_HISTORY"
}

# -----------------------------
# sqlboot CLI installation
# -----------------------------

write_launcher() {
  local tmp_file
  tmp_file="$(mktemp)"

  sed 's/^SQLBOOT_INSTALLED_MODE=.*/SQLBOOT_INSTALLED_MODE="1"/' "$0" >"$tmp_file"
  chmod +x "$tmp_file"

  log_info "Installing sqlboot command to $INSTALL_PATH"
  run_sudo mkdir -p "$(dirname "$INSTALL_PATH")"
  run_sudo install -m 0755 "$tmp_file" "$INSTALL_PATH"
  rm -f "$tmp_file"
  log_ok "Installed $INSTALL_PATH"
}

# This value is changed to "1" in /usr/local/bin/sqlboot by write_launcher.
SQLBOOT_INSTALLED_MODE="0"

# -----------------------------
# Launcher behavior
# -----------------------------

launch_sqlplus() {
  detect_os
  ensure_libaio_runtime
  ensure_docker_running
  start_oracle_container
  wait_for_oracle_ready

  local spath
  spath="$(sqlplus_path)"
  [[ -n "$spath" ]] || die "sqlplus was not found. Run the installer again: sqlboot init"

  export TNS_ADMIN="$TNS_ADMIN_DIR"
  export PATH="$(dirname "$spath"):$PATH"
  export "$LIB_PATH_VAR=$(dirname "$spath"):${!LIB_PATH_VAR:-}"

  require_command rlwrap

  log_info "Launching SQL*Plus"
  exec rlwrap -H "$SQLPLUS_HISTORY" "$spath" /nolog
}

show_status() {
  DETECT_OS_QUIET="1"
  detect_os

  printf 'Status\n'
  printf '  OS: %s (%s)\n' "$OS_TYPE" "$OS_ARCH"

  if command_exists docker; then
    printf '  Docker CLI: ok\n'
  else
    printf '  Docker CLI: missing\n'
  fi

  if docker_is_accessible; then
    printf '  Docker daemon: ok\n'
    if container_exists; then
      if container_is_running; then
        printf '  Oracle container: running\n'
      else
        printf '  Oracle container: stopped\n'
      fi
    else
      printf '  Oracle container: missing\n'
    fi
  else
    printf '  Docker daemon: not running\n'
    printf '  Oracle container: skipped\n'
  fi

  local spath
  spath="$(sqlplus_path)"
  if [[ -n "$spath" ]]; then
    printf '  SQL*Plus: ok\n'
  else
    printf '  SQL*Plus: missing\n'
  fi

  if [[ -f "$TNSNAMES_FILE" ]]; then
    printf '  TNS config: ok\n'
  else
    printf '  TNS config: missing\n'
  fi

  if [[ -x "$INSTALL_PATH" ]]; then
    printf '  Launcher: ok\n'
  else
    printf '  Launcher: missing\n'
  fi
}

show_logs() {
  DETECT_OS_QUIET="1"
  detect_os
  require_docker_ready
  container_exists || die "Container $ORACLE_CONTAINER does not exist."
  docker_cmd logs --tail 120 "$ORACLE_CONTAINER"
}

run_doctor() {
  DETECT_OS_QUIET="1"
  detect_os

  local failures=0
  local spath
  spath="$(sqlplus_path)"
  local next_step=""

  printf 'Doctor\n'
  printf '  OS: %s (%s)\n' "$OS_TYPE" "$OS_ARCH"

  if command_exists docker; then
    printf '  Docker CLI: ok\n'
  else
    printf '  Docker CLI: missing\n'
    failures=$((failures + 1))
    next_step="Install Docker first."
  fi

  if docker_is_accessible; then
    printf '  Docker daemon: ok\n'
  else
    printf '  Docker daemon: not running\n'
    failures=$((failures + 1))
    if [[ -z "$next_step" ]]; then
      if [[ "$OS_TYPE" == "macos" ]]; then
        next_step="Start Docker Desktop, wait until ready, rerun doctor."
      elif [[ "$IS_WSL" == "1" ]]; then
        next_step="Start Docker Desktop on Windows, enable WSL integration, rerun doctor."
      else
        next_step="Start Docker service, then rerun doctor."
      fi
    fi
  fi

  if [[ -n "$spath" ]]; then
    printf '  SQL*Plus: ok\n'
  else
    printf '  SQL*Plus: missing\n'
    failures=$((failures + 1))
    if [[ -z "$next_step" ]]; then
      next_step="Run `sqlboot init`."
    fi
  fi

  if [[ -f "$TNSNAMES_FILE" ]]; then
    printf '  TNS config: ok\n'
  else
    printf '  TNS config: missing\n'
    failures=$((failures + 1))
    if [[ -z "$next_step" ]]; then
      next_step="Run `sqlboot init`."
    fi
  fi

  if [[ -x "$INSTALL_PATH" ]]; then
    printf '  Launcher: ok\n'
  else
    printf '  Launcher: missing\n'
    failures=$((failures + 1))
    if [[ -z "$next_step" ]]; then
      next_step="Run `sqlboot init`."
    fi
  fi

  if docker_is_accessible; then
    if container_exists; then
      if container_is_running; then
        printf '  Oracle container: running\n'
      else
        printf '  Oracle container: stopped\n'
        failures=$((failures + 1))
        if [[ -z "$next_step" ]]; then
          next_step="Start container or rerun `sqlboot init`."
        fi
      fi
    else
      printf '  Oracle container: missing\n'
      failures=$((failures + 1))
      if [[ -z "$next_step" ]]; then
        next_step="Run `sqlboot init`."
      fi
    fi
  else
    printf '  Oracle container: skipped\n'
  fi

  if (( failures > 0 )); then
    printf '\nNext: %s\n' "$next_step" >&2
    die "Doctor found ${failures} issue(s)."
  fi

  printf '\nAll good.\n'
}

reset_password() {
  local new_password=${1:-}
  [[ -n "$new_password" ]] || die "Usage: sqlboot reset-pwd <new-password>"

  DETECT_OS_QUIET="1"
  detect_os
  require_docker_ready
  container_exists || die "Container $ORACLE_CONTAINER does not exist."

  log_info "Resetting Oracle password for $ORACLE_CONTAINER"
  docker_cmd exec "$ORACLE_CONTAINER" resetPassword "$new_password"
  log_ok "Oracle password reset complete"
}

stop_oracle_container() {
  DETECT_OS_QUIET="1"
  detect_os
  require_docker_ready

  if ! container_exists; then
    log_ok "Container $ORACLE_CONTAINER does not exist"
    return 0
  fi

  if ! container_is_running; then
    log_ok "Container $ORACLE_CONTAINER is already stopped"
    return 0
  fi

  log_info "Stopping container $ORACLE_CONTAINER"
  docker_cmd stop "$ORACLE_CONTAINER" >/dev/null
  log_ok "Container $ORACLE_CONTAINER stopped"
}

remove_oracle_container_and_image() {
  if ! command_exists docker; then
    log_ok "Docker CLI not found; skipping Oracle container and image cleanup"
    return 0
  fi

  if ! docker_is_accessible; then
    log_ok "Docker daemon is not reachable; skipping Oracle container and image cleanup"
    return 0
  fi

  if container_exists; then
    log_info "Removing container $ORACLE_CONTAINER"
    docker_cmd rm -f "$ORACLE_CONTAINER" >/dev/null
    log_ok "Removed container $ORACLE_CONTAINER"
  else
    log_ok "Container $ORACLE_CONTAINER does not exist"
  fi

  if docker_cmd image inspect "$ORACLE_IMAGE" >/dev/null 2>&1; then
    log_info "Removing image $ORACLE_IMAGE"
    if docker_cmd rmi "$ORACLE_IMAGE" >/dev/null 2>&1; then
      log_ok "Removed image $ORACLE_IMAGE"
    else
      log_info "Kept image $ORACLE_IMAGE because it is still used by Docker"
    fi
  else
    log_ok "Image $ORACLE_IMAGE does not exist"
  fi
}

remove_launcher() {
  if [[ -e "$INSTALL_PATH" || -L "$INSTALL_PATH" ]]; then
    log_info "Removing sqlboot command from $INSTALL_PATH"
    run_sudo rm -f "$INSTALL_PATH"
    log_ok "Removed $INSTALL_PATH"
  else
    log_ok "$INSTALL_PATH does not exist"
  fi
}

remove_environment() {
  local marker="# >>> sqlboot environment >>>"
  local end_marker="# <<< sqlboot environment <<<"
  remove_between_markers "$PROFILE_FILE" "$marker" "$end_marker"
}

run_uninstall() {
  local purge_flag=${1:-}
  if [[ -n "$purge_flag" && "$purge_flag" != "--purge" ]]; then
    invalid_command "uninstall $purge_flag"
  fi

  DETECT_OS_QUIET="1"
  detect_os

  log_info "Removing sqlboot-managed resources"
  remove_oracle_container_and_image
  remove_dir_if_exists "$INSTANTCLIENT_PARENT"
  rmdir "$ORACLE_BASE_DIR" 2>/dev/null || true
  remove_file_if_exists "$SQLPLUS_HISTORY"
  remove_environment
  remove_launcher

  log_info "Shared dependencies were left installed: Docker, curl, unzip, rlwrap, Homebrew, and apt packages."
  if [[ "$purge_flag" == "--purge" ]]; then
    log_info "Purge removes Windows-side Docker Desktop and WSL only when run from native Windows."
  fi
  printf '\nUninstall complete.\n'
}

# -----------------------------
# Installer flow
# -----------------------------

run_install() {
  detect_os
  install_required_packages
  install_and_setup_docker
  install_instant_client
  setup_tnsnames
  setup_environment
  setup_rlwrap
  write_launcher
  start_oracle_container
  wait_for_oracle_ready

  printf '\nSetup complete.\nRun:\nsqlboot\n\nThen inside SQL*Plus:\nconn system/%s@XE\n' "$ORACLE_PASSWORD"
}

print_usage() {
  cat <<EOF
sqlboot

Bootstrap Oracle SQL*Plus workflow with Docker Oracle XE, Instant Client, rlwrap, and local helper commands.

Usage:
  sqlboot                 Show this help
  sqlboot init            Run installer
  sqlboot help            Show help
  sqlboot start           Launch SQL*Plus
  sqlboot status          Show current sqlboot status
  sqlboot logs            Show Oracle container logs
  sqlboot doctor          Run local environment checks
  sqlboot reset-pwd <pw>  Reset Oracle password in running container
  sqlboot stop            Stop Oracle container
  sqlboot uninstall       Remove sqlboot-managed resources
  sqlboot uninstall --purge
                         Also remove Windows-side sqlboot setup when run from Windows

Available options:
  init                      Initialize sqlboot setup
  help                      Show help
  start                     Launch SQL*Plus
  status                    Show current sqlboot status
  logs                      Show recent Oracle container logs
  doctor                    Run environment checks
  stop                      Stop Oracle container
  uninstall                 Remove container, image, Instant Client, env block, history, and launcher
  reset-pwd <new-password>  Reset Oracle password

Authors:
  Shoaib Taimur      https://taimur.dev
  Toufiq Hasan Kiron https://kiron.dev

Environment overrides:
  SQLBOOT_ORACLE_PASSWORD
  SQLBOOT_ORACLE_IMAGE
  SQLBOOT_ORACLE_CONTAINER
  SQLBOOT_ORACLE_PORT
  SQLBOOT_ORACLE_SERVICE
  SQLBOOT_IC_BASIC_URL
  SQLBOOT_IC_SQLPLUS_URL
EOF
}

invalid_command() {
  die "Invalid command: $*. Use \"sqlboot help\" for usage."
}

require_no_extra_args() {
  local command_name=$1
  shift
  if (( $# > 0 )); then
    invalid_command "$command_name $*"
  fi
}

require_exact_arg_count() {
  local command_name=$1
  local expected_count=$2
  shift 2
  if (( $# != expected_count )); then
    invalid_command "$command_name $*"
  fi
}

main() {
  case "${1:-}" in
    help)
      require_no_extra_args "$1" "${@:2}"
      print_usage
      ;;
    init)
      require_no_extra_args "$1" "${@:2}"
      run_install
      ;;
    start)
      require_no_extra_args "$1" "${@:2}"
      launch_sqlplus
      ;;
    status)
      require_no_extra_args "$1" "${@:2}"
      show_status
      ;;
    logs)
      require_no_extra_args "$1" "${@:2}"
      show_logs
      ;;
    doctor)
      require_no_extra_args "$1" "${@:2}"
      run_doctor
      ;;
    reset-pwd)
      require_exact_arg_count "$1" 1 "${@:2}"
      reset_password "${2:-}"
      ;;
    stop)
      require_no_extra_args "$1" "${@:2}"
      stop_oracle_container
      ;;
    uninstall)
      if (( $# > 2 )) || { (( $# == 2 )) && [[ "${2:-}" != "--purge" ]]; }; then
        invalid_command "$@"
      fi
      run_uninstall "${2:-}"
      ;;
    "")
      print_usage
      ;;
    *)
      invalid_command "$@"
      ;;
  esac
}

main "$@"
